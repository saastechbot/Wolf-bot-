# WhatsApp Configuration
WHATSAPP_ENABLED=true

# Telegram Configuration
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Server Configuration
PORT=3000
HOST=localhost

# Bot Settings
PREFIX=!
OWNER_NUMBER=1234567890 # WhatsApp number with country code (e.g., +1234567890)
OWNER_TELEGRAM=123456789 # Your Telegram chat ID
AUTO_REPLY=true
WELCOME_MESSAGE=Welcome to Wolf-bot! 🤖

# Logging
LOG_LEVEL=error

# Database Configuration (optional)
DB_ENABLED=false
DB_TYPE=sqlite
DB_PATH=./data/bot.db
